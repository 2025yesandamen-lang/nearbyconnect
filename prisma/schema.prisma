model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  latitude  Float?
  longitude Float?
  online    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  roomId    String
  senderId  String
  text      String
  createdAt DateTime @default(now())
}

model Match {
  id        String   @id @default(cuid())
  userA     String
  userB     String
  matched   Boolean  @default(false)
  createdAt DateTime @default(now())
}
model Waitlist {
  id    String @id @default(cuid())
  email String @unique
}